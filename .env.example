# Healthcare Autopilot — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# ============================================================
# REQUIRED — Qwen Cloud (Alibaba Cloud Model Studio / DashScope)
# ============================================================
# Get your key: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# DashScope API endpoint (default, usually no need to change)
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================================
# OPTIONAL — Alibaba Cloud Services
# ============================================================

# RDS PostgreSQL connection
RDS_CONNECTION_STRING=postgresql://user:pass@pgm-xxx.pg.rds.aliyuncs.com:5432/healthcare

# Alibaba Cloud credentials (for OSS, ECS management)
ALIBABA_CLOUD_ACCESS_KEY_ID=your-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-access-key-secret

# Redis / Tair (session state)
REDIS_URL=redis://localhost:6379/0

# ============================================================
# APPLICATION CONFIG
# ============================================================
LOG_LEVEL=INFO
ENVIRONMENT=development
PORT=8000
